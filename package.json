{
  "name": "obsidian-subtitles-md",
  "version": "0.1.0",
  "description": "An Obsidian plugin that reads .srt/.vtt transcripts as readable, searchable Markdown.",
  "main": "main.js",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "install:vault": "pnpm run build && node scripts/install-to-vault.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wdio run wdio.conf.mts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Pedro Fuentes",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3",
    "@wdio/cli": "^9.29.0",
    "@wdio/globals": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.0",
    "esbuild": "^0.25",
    "eslint": "^9",
    "eslint-plugin-obsidianmd": "^0.3",
    "globals": "^16",
    "mocha": "^10.8.2",
    "obsidian": "latest",
    "tsx": "^4.22.4",
    "typescript": "^5.8",
    "typescript-eslint": "^8",
    "vitest": "^3",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  }
}
